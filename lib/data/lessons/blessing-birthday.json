      "words": [
        {"id": "s03-0", "hanzi": "这", "pinyin": "zhè", "meaning": "this"},
        {"id": "s03-1", "hanzi": "是", "pinyin": "shì", "meaning": "is"},
        {"id": "s03-2", "hanzi": "给你的", "pinyin": "gěi nǐ de", "meaning": "for you"},
