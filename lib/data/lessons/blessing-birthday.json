    {
      "id": "s01",
      "text": "生日快乐！",
      "pinyin": "Shēngrì kuàilè!",
      "translation": "Happy birthday!",
      "words": [
        {"id": "s01-0", "hanzi": "生日", "pinyin": "shēngrì", "meaning": "birthday"},
        {"id": "s01-1", "hanzi": "快乐", "pinyin": "kuàilè", "meaning": "happy"},
        {"id": "s01-2", "hanzi": "！", "pinyin": "!", "meaning": ""}
      ]
    },
    {
      "id": "s02",
      "text": "祝你天天开心，越来越漂亮！",
      "pinyin": "Zhù nǐ tiāntiān kāixīn, yuè lái yuè piàoliang!",
      "translation": "Wishing you happiness every day, and growing more beautiful!",
      "words": [
        {"id": "s02-0", "hanzi": "祝", "pinyin": "zhù", "meaning": "wish"},
        {"id": "s02-1", "hanzi": "你", "pinyin": "nǐ", "meaning": "you"},
        {"id": "s02-2", "hanzi": "天天", "pinyin": "tiāntiān", "meaning": "every day"},
        {"id": "s02-3", "hanzi": "开心", "pinyin": "kāixīn", "meaning": "happy"},
        {"id": "s02-4", "hanzi": "，", "pinyin": ",", "meaning": ""},
        {"id": "s02-5", "hanzi": "越来越", "pinyin": "yuè lái yuè", "meaning": "more and more"},
