        {"id": "s07-9", "hanzi": "，", "pinyin": ","},
        {"id": "s07-10", "hanzi": "我", "pinyin": "wǒ"},
        {"id": "s07-11", "hanzi": "是", "pinyin": "shì"},
        {"id": "s07-12", "hanzi": "新鬼", "pinyin": "xīn guǐ"},
