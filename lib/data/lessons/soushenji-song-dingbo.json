        {"id": "s01-0", "hanzi": "很久以前", "pinyin": "hěn jiǔ yǐqián"},
        {"id": "s01-1", "hanzi": "，", "pinyin": ","},
        {"id": "s01-2", "hanzi": "有", "pinyin": "yǒu"},
        {"id": "s01-3", "hanzi": "一个", "pinyin": "yí gè"},
        {"id": "s01-4", "hanzi": "年轻人", "pinyin": "niánqīng rén"},
        {"id": "s01-5", "hanzi": "叫", "pinyin": "jiào"},
        {"id": "s01-6", "hanzi": "宋定伯", "pinyin": "Sòng Dìngbó"},
        {"id": "s01-7", "hanzi": "。", "pinyin": "."}
      ]
    },
    {
      "id": "s02",
      "text": "一天晚上，他一个人走路去城里。",
      "pinyin": "Yì tiān wǎnshang, tā yí gè rén zǒulù qù chéng lǐ.",
