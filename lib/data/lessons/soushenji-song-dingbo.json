        {"id": "s04-5", "hanzi": "是", "pinyin": "shì"},
        {"id": "s04-6", "hanzi": "谁", "pinyin": "shéi"},
        {"id": "s04-7", "hanzi": "？", "pinyin": "?"}
      ]
    },
    {
