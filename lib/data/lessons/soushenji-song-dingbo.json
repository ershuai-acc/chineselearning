        {"id": "s03-0", "hanzi": "路上", "pinyin": "lù shàng"},
        {"id": "s03-1", "hanzi": "很", "pinyin": "hěn"},
        {"id": "s03-2", "hanzi": "黑", "pinyin": "hēi"},
        {"id": "s03-3", "hanzi": "，", "pinyin": ","},
        {"id": "s03-4", "hanzi": "他", "pinyin": "tā"},
        {"id": "s03-5", "hanzi": "突然", "pinyin": "tūrán"},
        {"id": "s03-6", "hanzi": "看见", "pinyin": "kànjiàn"},
        {"id": "s03-7", "hanzi": "一个", "pinyin": "yí gè"},
        {"id": "s03-8", "hanzi": "人", "pinyin": "rén"},
        {"id": "s03-9", "hanzi": "。", "pinyin": "."}
      ]
    },
    {
