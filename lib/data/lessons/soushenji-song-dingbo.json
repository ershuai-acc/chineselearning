        {"id": "s05-0", "hanzi": "那个", "pinyin": "nà gè"},
        {"id": "s05-1", "hanzi": "人", "pinyin": "rén"},
        {"id": "s05-2", "hanzi": "说", "pinyin": "shuō"},
        {"id": "s05-3", "hanzi": "：", "pinyin": ":"},
        {"id": "s05-4", "hanzi": "我", "pinyin": "wǒ"},
        {"id": "s05-5", "hanzi": "是", "pinyin": "shì"},
        {"id": "s05-6", "hanzi": "鬼", "pinyin": "guǐ"},
        {"id": "s05-7", "hanzi": "。", "pinyin": "."},
        {"id": "s05-8", "hanzi": "你", "pinyin": "nǐ"},
        {"id": "s05-9", "hanzi": "呢", "pinyin": "ne"},
        {"id": "s05-10", "hanzi": "？", "pinyin": "?"}
