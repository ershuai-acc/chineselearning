        {"id": "s02-1", "hanzi": "晚上", "pinyin": "wǎnshang"},
        {"id": "s02-2", "hanzi": "，", "pinyin": ","},
        {"id": "s02-3", "hanzi": "他", "pinyin": "tā"},
        {"id": "s02-4", "hanzi": "一个人", "pinyin": "yí gè rén"},
        {"id": "s02-5", "hanzi": "走路", "pinyin": "zǒulù"},
        {"id": "s02-6", "hanzi": "去", "pinyin": "qù"},
        {"id": "s02-7", "hanzi": "城里", "pinyin": "chéng lǐ"},
        {"id": "s02-8", "hanzi": "。", "pinyin": "."}
      ]
    },
    {
      "id": "s03",
      "text": "路上很黑，他突然看见一个人。",
      "pinyin": "Lù shàng hěn hēi, tā tūrán kànjiàn yí gè rén.",
