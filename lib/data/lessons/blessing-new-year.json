  "sentences": [
    {
      "id": "s01",
      "text": "恭喜发财！",
      "pinyin": "Gōngxǐ fācái!",
      "translation": "Wishing you wealth and prosperity!",
      "words": [
        {"id": "s01-0", "hanzi": "恭喜", "pinyin": "gōngxǐ", "meaning": "congratulations"},
        {"id": "s01-1", "hanzi": "发财", "pinyin": "fācái", "meaning": "get rich"},
        {"id": "s01-2", "hanzi": "！", "pinyin": "!", "meaning": ""}
      ]
    },
    {
      "id": "s02",
      "text": "新年快乐！万事如意！",
      "pinyin": "Xīnnián kuàilè! Wànshì rúyì!",
      "translation": "Happy New Year! May everything go as you wish!",
      "words": [
        {"id": "s02-0", "hanzi": "新年", "pinyin": "xīnnián", "meaning": "new year"},
        {"id": "s02-1", "hanzi": "快乐", "pinyin": "kuàilè", "meaning": "happy"},
        {"id": "s02-2", "hanzi": "！", "pinyin": "!", "meaning": ""},
        {"id": "s02-3", "hanzi": "万事", "pinyin": "wànshì", "meaning": "all things"},
        {"id": "s02-4", "hanzi": "如意", "pinyin": "rúyì", "meaning": "as you wish"},
        {"id": "s02-5", "hanzi": "！", "pinyin": "!", "meaning": ""}
      ]
    },
    {
