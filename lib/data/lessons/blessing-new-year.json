        {"id": "s03-2", "hanzi": "年年", "pinyin": "niánnián", "meaning": "every year"},
        {"id": "s03-3", "hanzi": "有余", "pinyin": "yǒu yú", "meaning": "have surplus"},
        {"id": "s03-4", "hanzi": "！", "pinyin": "!", "meaning": ""}
      ]
    },
    {
      "id": "s04",
      "text": "身体健康！工作顺利！",
