        {"id": "s04-1", "hanzi": "健康", "pinyin": "jiànkāng", "meaning": "healthy"},
        {"id": "s04-2", "hanzi": "！", "pinyin": "!", "meaning": ""},
        {"id": "s04-3", "hanzi": "工作", "pinyin": "gōngzuò", "meaning": "work"},
